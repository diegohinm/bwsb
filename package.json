{
  "name": "reddit-radar-bwsb",
  "version": "1.0.0",
  "description": "Backend for StonkTerminal, internally known as bwsb.",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:setup": "tsx src/scripts/setupDatabase.ts",
    "db:seed": "tsx src/scripts/seedDatabase.ts",
    "db:drop": "tsx src/scripts/dropDatabase.ts",
    "db:reset": "npm run db:drop && npm run db:setup && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.45.4",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "prisma": "6.19.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
