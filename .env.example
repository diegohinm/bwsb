# ── bwsb backend environment ─────────────────────────────────────────────────
# Server-side only. Never expose these values to the frontend. Do not commit the
# real .env file.

PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Supabase REST client (existing tickers feature).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App database (raw pg pool + Prisma + auth tables). Postgres connection string.
DATABASE_URL=

# Session signing secret (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
APP_SESSION_SECRET=

# ── Email (verification links + password resets) ─────────────────────────────
EMAIL_FROM=YOLOPulse <no-reply@yolopulse.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# When true (or when SMTP is not configured) verification/reset links are printed
# to the backend console instead of being emailed. Must be false in production.
DEV_EMAIL_MODE=true

# ── Reddit OAuth 2.0 (OPTIONAL / future) ─────────────────────────────────────
# Leave blank to run without Reddit login. When you are ready, create a "web app"
# at https://www.reddit.com/prefs/apps and fill these in. The app starts fine
# without them; /auth/reddit returns 503 until all four are set to real values.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:4000/auth/reddit/callback
REDDIT_USER_AGENT=YOLOPulse/0.1 by YOUR_REDDIT_USERNAME

# ── Optional Reddit username verification (inbound message flow) ──────────────
# The Reddit account users send their verification code to (inbound only — the
# app never sends DMs). Admin reviews the inbox and approves via ADMIN_SECRET.
REDDIT_VERIFICATION_USERNAME=yolo-terminal
ADMIN_SECRET=

# ── Social data provider (Reddit-like posts/comments/pulse) ──────────────────
# The app never scrapes Reddit. Social data comes from a swappable third-party
# provider queried server-side, or from centralized local demo fixtures.
#   mock | mindcase | brandwatch | reddit_official | off
# `off` disables the Pulse data feed and demo data is served with a warning.
# A real provider without its API key automatically falls back to mock and the
# response is flagged isMock=true with a warning.
SOCIAL_DATA_PROVIDER=mock

# Seconds a social payload is cached before the provider is queried again.
SOCIAL_DATA_CACHE_TTL_SECONDS=600

# Third-party provider credentials. Backend-only — never sent to the frontend.
# When SOCIAL_DATA_PROVIDER=mindcase, both must be set or the provider reports
# "misconfigured" and the app serves mock fallback.
MINDCASE_API_KEY=
MINDCASE_BASE_URL=

# ── Market data provider (equities / extended-hours / options) ───────────────
# Fully separate from the social provider above. Provider keys are read only by
# the backend and never sent to the frontend. Real-time / overnight / options
# real-time PUBLIC display are gated by the license flags below — nothing legal-
# sensitive is ever enabled implicitly.
#   mock | databento | polygon | alpaca | twelvedata
MARKET_DATA_PROVIDER=mock
# Equities/movers cache TTL (seconds). Options use their own longer TTL below.
MARKET_DATA_CACHE_TTL_SECONDS=5
OPTIONS_CACHE_TTL_SECONDS=60

# Intended default display mode: mock | delayed | realtime | end_of_day.
# `realtime` is only honored when the license flags below explicitly allow it.
MARKET_DATA_DISPLAY_MODE=delayed

# ── License / legal display flags (ALL default false) ────────────────────────
# Public real-time display requires LICENSE_CONFIRMED=true AND the matching
# ALLOW_* flag. Until then the service serves delayed/EOD/mock data with a
# warning. Never set these true without a confirmed market-data license.
MARKET_DATA_LICENSE_CONFIRMED=false
MARKET_DATA_ALLOW_PUBLIC_REALTIME=false
MARKET_DATA_ALLOW_PUBLIC_OPTIONS_REALTIME=false
MARKET_DATA_ALLOW_PUBLIC_OVERNIGHT=false

# ── Databento (first real provider) — backend-only credentials ───────────────
# App runs fine with these blank (falls back to mock). If MARKET_DATA_PROVIDER=
# databento but DATABENTO_API_KEY is missing, status is "misconfigured" and mock
# fallback is served with a warning.
DATABENTO_API_KEY=
# Historical/REST base. Default https://hist.databento.com when blank.
DATABENTO_BASE_URL=
# Live streaming is a separate DBN/TCP runtime — left as a documented boundary.
DATABENTO_LIVE_ENABLED=false

# Account-approved dataset ids (do NOT guess — copy from your Databento account):
#   equities        e.g. EQUS.MINI  or your approved equities dataset
#   extended hours  e.g. EQUS.MINI  or your approved extended-hours dataset
#   overnight       e.g. OCEA.MEMOIR or your approved overnight dataset
#   options         e.g. OPRA.PILLAR or your approved options dataset
DATABENTO_EQUITIES_DATASET=
DATABENTO_EXTENDED_HOURS_DATASET=
DATABENTO_OVERNIGHT_DATASET=
DATABENTO_OPTIONS_DATASET=

# Account-approved schema names (e.g. trades, mbp-1, ohlcv-1m, cmbp-1, tbbo…):
DATABENTO_EQUITIES_SCHEMA=
DATABENTO_OPTIONS_SCHEMA=
DATABENTO_OVERNIGHT_SCHEMA=

# Symbology types passed to Databento requests.
DATABENTO_DEFAULT_STYPE_IN=raw_symbol
DATABENTO_DEFAULT_STYPE_OUT=instrument_id
