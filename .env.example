# ── bwsb backend environment ─────────────────────────────────────────────────
# Server-side only. Never expose these values to the frontend. Do not commit the
# real .env file.

PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Supabase REST client (existing tickers feature).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App database (raw pg pool + Prisma + auth tables). Postgres connection string.
DATABASE_URL=

# Session signing secret (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
APP_SESSION_SECRET=

# ── Email (verification links + password resets) ─────────────────────────────
EMAIL_FROM=YOLOPulse <no-reply@yolopulse.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# When true (or when SMTP is not configured) verification/reset links are printed
# to the backend console instead of being emailed. Must be false in production.
DEV_EMAIL_MODE=true

# ── Reddit OAuth 2.0 (OPTIONAL / future) ─────────────────────────────────────
# Leave blank to run without Reddit login. When you are ready, create a "web app"
# at https://www.reddit.com/prefs/apps and fill these in. The app starts fine
# without them; /auth/reddit returns 503 until all four are set to real values.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:4000/auth/reddit/callback
REDDIT_USER_AGENT=YOLOPulse/0.1 by YOUR_REDDIT_USERNAME

# ── Optional Reddit username verification (inbound message flow) ──────────────
# The Reddit account users send their verification code to (inbound only — the
# app never sends DMs). Admin reviews the inbox and approves via ADMIN_SECRET.
REDDIT_VERIFICATION_USERNAME=yolo-terminal
ADMIN_SECRET=

# ── Social data provider (Reddit-like posts/comments/pulse) ──────────────────
# The app never scrapes Reddit. Social data comes from a swappable third-party
# provider queried server-side, or from centralized local demo fixtures.
#   mock | mindcase | brandwatch | reddit_official | off
# `off` disables the Pulse data feed and demo data is served with a warning.
# A real provider without its API key automatically falls back to mock and the
# response is flagged isMock=true with a warning.
SOCIAL_DATA_PROVIDER=mock

# Seconds a social payload is cached before the provider is queried again.
SOCIAL_DATA_CACHE_TTL_SECONDS=600

# Third-party provider credentials. Backend-only — never sent to the frontend.
# When SOCIAL_DATA_PROVIDER=mindcase, both must be set or the provider reports
# "misconfigured" and the app serves mock fallback.
MINDCASE_API_KEY=
MINDCASE_BASE_URL=

# ── Market data provider (equities + overnight) ──────────────────────────────
# Fully separate from the social provider above. Provider keys are read only by
# the backend and never sent to the frontend.
#
# INTENTIONALLY MINIMAL: the six vars below are the ONLY market-data settings.
# Base URL, equities/overnight/options schemas, the options dataset, symbology
# types and the live/real-time/overnight PUBLIC toggles are internal code
# defaults — see bwsb/src/services/market-data/providers/databento.config.ts.
#   mock | databento | polygon | alpaca | twelvedata
MARKET_DATA_PROVIDER=databento
# Safe display mode: mock | delayed | realtime | end_of_day. `delayed` is the
# default and data is never presented as real-time in safe mode.
MARKET_DATA_MODE=delayed
MARKET_DATA_CACHE_TTL_SECONDS=10

# ── Databento — backend-only credentials ─────────────────────────────────────
# App runs fine with a blank key (status "misconfigured" → mock fallback with a
# warning; never crashes). The two datasets default in code if left blank.
DATABENTO_API_KEY=db_TU_API_KEY_REAL
DATABENTO_DATASET=EQUS.MINI
DATABENTO_OVERNIGHT_DATASET=OCEA.MEMOIR
