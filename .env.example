# ── bwsb backend environment ─────────────────────────────────────────────────
# Server-side only. Never expose these values to the frontend.

PORT=4000
NODE_ENV=development

# Public URLs. FRONTEND_URL is also the only allowed CORS origin.
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# App database (Prisma + PostgreSQL session store).
# Must be a Postgres connection string — NOT the Supabase HTTP URL.
DATABASE_URL=postgresql://user:password@host:5432/database

# Supabase REST client (existing tickers feature).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Session signing secret (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Reddit OAuth 2.0 — create a "web app" at https://www.reddit.com/prefs/apps
# REDDIT_REDIRECT_URI must exactly match the redirect URI registered on Reddit
# and should be <BACKEND_URL>/auth/reddit/callback.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:4000/auth/reddit/callback
